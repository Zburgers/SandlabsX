# Copy to .env before exposing SandLabX outside a local development machine.
POSTGRES_USER=guacamole_user
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=guacamole_db
JWT_SECRET=replace-with-at-least-32-random-characters
ALLOWED_ORIGINS=http://localhost:3000

FRONTEND_PORT=3000
BACKEND_PORT=3001
GUACAMOLE_PORT=8081
POSTGRES_PORT=5432

# Keep false unless your host networking setup requires legacy privileged mode.
SANDLABX_PRIVILEGED=false
NODE_ENV=development
