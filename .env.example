# Copy to .env before exposing SandLabX outside a local development machine.
POSTGRES_USER=guacamole_user
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=guacamole_db
JWT_SECRET=replace-with-at-least-32-random-characters
ALLOWED_ORIGINS=http://localhost:2000

# Development-only first-start admin. Change immediately after first login.
SANDBOXX_ADMIN_EMAIL=admin@sandlabx.com
SANDBOXX_ADMIN_PASSWORD=admin123

# The Guacamole runtime and vendor-schema initializer use the same pinned version.
# Review the corresponding Guacamole database upgrade scripts before changing it.
GUACAMOLE_VERSION=1.5.4

# Bind published ports to loopback by default so the development stack is not
# exposed to the LAN. Set 0.0.0.0 only after reviewing authentication/firewalling.
BIND_ADDRESS=127.0.0.1
FRONTEND_PORT=2000
BACKEND_PORT=3001
GUACAMOLE_PORT=8081
POSTGRES_PORT=5432

# These NEXT_PUBLIC values are baked into the frontend image during `make rebuild`.
# Change localhost to the browser-reachable hostname/IP for remote access, then
# rebuild the frontend image. Runtime-only changes do not rewrite a Next.js bundle.
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_GUAC_URL=http://localhost:8081/guacamole

# Compose builds production frontend/backend images. Use an explicit development
# override for hot reload rather than bind-mounting source over production images.
NODE_ENV=production

# SandLabX schema changes are applied by the one-shot `migrate` service through
# node-pg-migrate before the backend is allowed to start. Enable only for detailed
# migration SQL/debug output.
SANDLABX_MIGRATION_VERBOSE=false

# LEGACY compatibility mode for the pre-Capsule QemuManager. It creates two
# unnumbered Layer-2 bridges inside the backend container only. Replace with
# plan-only/disabled after the Capsule LocalRunner executes compiled networks.
SANDLABX_NETWORK_MODE=legacy-l2

# Keep false. Eager qemu-img scans/downloads are intentionally removed from
# normal API startup; use `make image-init` or ImagePipeline commands explicitly.
SANDLABX_VALIDATE_IMAGES_ON_STARTUP=false
AUTO_DOWNLOAD_IMAGES=false

# Used by scripts/stack.sh when the installed Compose plugin supports --wait.
SANDLABX_STARTUP_TIMEOUT=180
