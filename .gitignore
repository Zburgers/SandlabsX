# Logs and process state
*.log
*.pid
pids/

# Dependencies and build output
node_modules/
**/node_modules/
frontend/.next/
frontend/out/
frontend/build/
backend/dist/
backend/build/
coverage/
.nyc_output/
.cache/

# Environment and secrets
.env
.env.local
.env.*.local
!.env.example

# Runtime databases and state
pgdata/
backend/nodes-state.json

# VM runtime data and large disk formats
overlays/
vms/
*.qcow2
*.vmdk
*.vdi
*.vhd
*.vhdx
*.iso
*.img
*.raw

# Keep the appliance catalog while ignoring downloaded images
images/*
!images/catalog.json
!images/custom/
images/custom/*
!images/custom/.gitkeep

# Temporary files
*.tmp
*.temp
*.bak
*~

# Editor and OS files
.DS_Store
Thumbs.db
.directory
.vscode/
.idea/
*.swp
*.swo
*.swn

# Package manager diagnostics
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Development artifacts
EVALUATION-*.md
VERIFICATION-*.md
FIXES.md
WORKFLOW-*.md
SYSTEM-*.md
CLEANUP-*.md
