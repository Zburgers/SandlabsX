{
  "apiVersion": "sandlabx.io/v1alpha1",
  "kind": "LabCapsule",
  "metadata": {
    "name": "ospf-failure-recovery",
    "displayName": "OSPF failure and recovery",
    "description": "Diagnose a failed transit link, restore adjacency, and verify the result.",
    "tags": ["networking", "ospf", "recovery"]
  },
  "runtime": { "architecture": "x86_64", "acceleration": "required", "isolation": "private", "estimatedDurationMinutes": 45 },
  "policy": {
    "resources": { "maxVcpus": 6, "maxMemoryMiB": 6144, "maxDiskGiB": 40 },
    "network": { "internetEgress": false, "externalConnectors": [] },
    "execution": { "allowAuthorScripts": false }
  },
  "images": {
    "router": { "source": "managed", "name": "router", "version": "router-image-v1", "digest": "sha256:3333333333333333333333333333333333333333333333333333333333333333" }
  },
  "workloadProfiles": { "router": { "version": "qemu-serial-router-v1" } },
  "nodes": {
    "r1": { "displayName": "Router 1", "driver": "qemu-serial-router", "image": "router", "workloadProfile": "router", "role": "router", "resources": { "vcpus": 1, "memoryMiB": 2048 }, "interfaces": [{ "id": "ge0" }, { "id": "ge1" }], "console": { "type": "serial" }, "position": { "x": 80, "y": 180 } },
    "r2": { "displayName": "Router 2", "driver": "qemu-serial-router", "image": "router", "workloadProfile": "router", "role": "router", "resources": { "vcpus": 1, "memoryMiB": 2048 }, "interfaces": [{ "id": "ge0" }, { "id": "ge1" }], "console": { "type": "serial" }, "position": { "x": 380, "y": 180 } },
    "r3": { "displayName": "Router 3", "driver": "qemu-serial-router", "image": "router", "workloadProfile": "router", "role": "router", "resources": { "vcpus": 1, "memoryMiB": 2048 }, "interfaces": [{ "id": "ge0" }, { "id": "ge1" }], "console": { "type": "serial" }, "position": { "x": 680, "y": 180 } }
  },
  "links": [
    { "id": "r1-r2", "type": "pointToPoint", "endpoints": ["r1:ge0", "r2:ge0"] },
    { "id": "r2-r3", "type": "pointToPoint", "endpoints": ["r2:ge1", "r3:ge0"] },
    { "id": "r3-r1", "type": "pointToPoint", "endpoints": ["r3:ge1", "r1:ge1"] }
  ]
}
