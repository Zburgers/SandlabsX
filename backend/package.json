{
  "name": "sandboxlabs-backend",
  "version": "1.0.0",
  "description": "SandLabX backend API and virtualization tooling",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node --test test/*.test.js",
    "test:watch": "node --test --watch test/*.test.js",
    "sandlabx": "node cli/sandlabx.js",
    "image:doctor": "node cli/sandlabx.js image doctor",
    "image:list": "node cli/sandlabx.js image list",
    "lab:validate": "node cli/sandlabx.js lab validate",
    "check": "npm test && node -c server.js && node -c modules/imagePipeline.js && node -c modules/labSpec.js && node -c cli/sandlabx.js"
  },
  "keywords": [
    "qemu",
    "kvm",
    "qcow2",
    "guacamole",
    "vm",
    "network-lab"
  ],
  "author": "SandLabX contributors",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-jwt": "^8.5.1",
    "express-rate-limit": "^8.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.0",
    "pg": "^8.11.0",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
